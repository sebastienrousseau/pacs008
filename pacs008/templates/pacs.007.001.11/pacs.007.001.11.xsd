            <xs:element maxOccurs="1" minOccurs="0" name="OrgnlGrpInf" type="OriginalGroupInformation29"/>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="TxInf" type="PaymentTransaction110"/>
