{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pacs.028.001.05 Payment Data Schema",
  "description": "Schema for ISO 20022 pacs.028.001.05 FI-to-FI Payment Status Request",
  "version": "0.0.1",
  "type": "object",
  "required": [
    "msg_id",
    "creation_date_time",
    "original_msg_id",
    "original_msg_nm_id"
  ],
  "properties": {
    "msg_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 35,
      "description": "Message identification"
    },
    "creation_date_time": {
      "type": "string",
      "description": "Creation date and time"
    },
    "original_msg_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 35,
      "description": "Original message identification"
    },
    "original_msg_nm_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 35,
      "description": "Original message name identification"
    },
    "original_end_to_end_id": {
      "type": "string",
      "maxLength": 35,
      "description": "Original end-to-end identification"
    },
    "original_tx_id": {
      "type": "string",
      "maxLength": 35,
      "description": "Original transaction identification"
    },
    "instg_agt_bic": {
      "type": "string",
      "pattern": "^[A-Z0-9]{6}[A-Z0-9]{2}([A-Z0-9]{3})?$",
      "description": "Instructing agent BIC"
    },
    "instd_agt_bic": {
      "type": "string",
      "pattern": "^[A-Z0-9]{6}[A-Z0-9]{2}([A-Z0-9]{3})?$",
      "description": "Instructed agent BIC"
    }
  },
  "additionalProperties": true
}
