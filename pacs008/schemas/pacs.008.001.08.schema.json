{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pacs.008.001.08 Payment Data Schema",
  "description": "Schema for ISO 20022 pacs.008.001.08 FI-to-FI Customer Credit Transfer",
  "version": "0.0.1",
  "type": "object",
  "required": [
    "msg_id",
    "creation_date_time",
    "nb_of_txs",
    "settlement_method",
    "end_to_end_id",
    "interbank_settlement_amount",
    "interbank_settlement_currency",
    "charge_bearer",
    "debtor_name",
    "debtor_agent_bic",
    "creditor_agent_bic",
    "creditor_name",
    "uetr"
  ],
  "properties": {
    "msg_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 35,
      "description": "Message identification (unique identifier)"
    },
    "creation_date_time": {
      "type": "string",
      "description": "Creation date and time of the message"
    },
    "nb_of_txs": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of transactions"
    },
    "settlement_method": {
      "type": "string",
      "enum": ["INGA", "INDA", "CLRG", "COVE"],
      "description": "Settlement method"
    },
    "end_to_end_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 35,
      "description": "End-to-end transaction identifier"
    },
    "interbank_settlement_amount": {
      "type": "number",
      "minimum": 0.01,
      "maximum": 999999999.99,
      "description": "Interbank settlement amount"
    },
    "interbank_settlement_currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$",
      "description": "ISO 4217 currency code"
    },
    "charge_bearer": {
      "type": "string",
      "enum": ["DEBT", "CRED", "SHAR", "SLEV"],
      "description": "Charge bearer code"
    },
    "debtor_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 140,
      "description": "Name of the debtor"
    },
    "debtor_agent_bic": {
      "type": "string",
      "pattern": "^[A-Z0-9]{6}[A-Z0-9]{2}([A-Z0-9]{3})?$",
      "description": "Debtor agent BIC code"
    },
    "creditor_agent_bic": {
      "type": "string",
      "pattern": "^[A-Z0-9]{6}[A-Z0-9]{2}([A-Z0-9]{3})?$",
      "description": "Creditor agent BIC code"
    },
    "creditor_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 140,
      "description": "Name of the creditor"
    },
    "uetr": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "description": "Unique End-to-End Transaction Reference (UUID v4)"
    },
    "tx_id": {
      "type": "string",
      "maxLength": 35,
      "description": "Transaction identification"
    },
    "debtor_account_iban": {
      "type": "string",
      "pattern": "^[A-Z]{2}[0-9]{2}[A-Z0-9]+$",
      "minLength": 15,
      "maxLength": 34,
      "description": "Debtor account IBAN"
    },
    "creditor_account_iban": {
      "type": "string",
      "pattern": "^[A-Z]{2}[0-9]{2}[A-Z0-9]+$",
      "minLength": 15,
      "maxLength": 34,
      "description": "Creditor account IBAN"
    },
    "remittance_information": {
      "type": "string",
      "maxLength": 140,
      "description": "Remittance information"
    },
    "interbank_settlement_date": {
      "type": "string",
      "description": "Interbank settlement date"
    },
    "instd_amount": {
      "type": "number",
      "description": "Instructed amount"
    },
    "instd_currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$",
      "description": "Instructed currency (ISO 4217)"
    }
  },
  "additionalProperties": true
}
