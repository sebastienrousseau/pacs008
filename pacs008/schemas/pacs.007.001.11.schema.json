{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pacs.007.001.11 Payment Data Schema",
  "description": "Schema for ISO 20022 pacs.007.001.11 FI-to-FI Payment Reversal",
  "version": "0.0.1",
  "type": "object",
  "required": [
    "msg_id",
    "creation_date_time",
    "original_msg_id",
    "original_msg_nm_id",
    "reversed_interbank_settlement_amount",
    "reversed_interbank_settlement_currency",
    "reversal_reason_cd"
  ],
  "properties": {
    "msg_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 35,
      "description": "Message identification"
    },
    "creation_date_time": {
      "type": "string",
      "description": "Creation date and time"
    },
    "nb_of_txs": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of transactions"
    },
    "original_msg_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 35,
      "description": "Original message identification"
    },
    "original_msg_nm_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 35,
      "description": "Original message name identification"
    },
    "original_end_to_end_id": {
      "type": "string",
      "maxLength": 35,
      "description": "Original end-to-end identification"
    },
    "original_tx_id": {
      "type": "string",
      "maxLength": 35,
      "description": "Original transaction identification"
    },
    "reversed_interbank_settlement_amount": {
      "type": "number",
      "minimum": 0.01,
      "maximum": 999999999.99,
      "description": "Reversed interbank settlement amount"
    },
    "reversed_interbank_settlement_currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$",
      "description": "Reversed interbank settlement currency (ISO 4217)"
    },
    "reversal_reason_cd": {
      "type": "string",
      "maxLength": 4,
      "description": "Reversal reason code (e.g., DUPL, TECH, FRAD)"
    },
    "reversal_reason_addtl_inf": {
      "type": "string",
      "maxLength": 105,
      "description": "Reversal reason additional information"
    },
    "instg_agt_bic": {
      "type": "string",
      "pattern": "^[A-Z0-9]{6}[A-Z0-9]{2}([A-Z0-9]{3})?$",
      "description": "Instructing agent BIC"
    },
    "instd_agt_bic": {
      "type": "string",
      "pattern": "^[A-Z0-9]{6}[A-Z0-9]{2}([A-Z0-9]{3})?$",
      "description": "Instructed agent BIC"
    }
  },
  "additionalProperties": true
}
