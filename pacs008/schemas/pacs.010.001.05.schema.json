{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pacs.010.001.05 Payment Data Schema",
  "description": "Schema for ISO 20022 pacs.010.001.05 Financial Institution Direct Debit",
  "version": "0.0.1",
  "type": "object",
  "required": [
    "msg_id",
    "creation_date_time",
    "nb_of_txs",
    "settlement_method",
    "end_to_end_id",
    "interbank_settlement_amount",
    "interbank_settlement_currency",
    "debtor_agent_bic",
    "creditor_agent_bic"
  ],
  "properties": {
    "msg_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 35,
      "description": "Message identification"
    },
    "creation_date_time": {
      "type": "string",
      "description": "Creation date and time"
    },
    "nb_of_txs": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of transactions"
    },
    "settlement_method": {
      "type": "string",
      "enum": [
        "INGA",
        "INDA",
        "CLRG",
        "COVE"
      ],
      "description": "Settlement method"
    },
    "end_to_end_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 35,
      "description": "End-to-end transaction identifier"
    },
    "tx_id": {
      "type": "string",
      "maxLength": 35,
      "description": "Transaction identification"
    },
    "interbank_settlement_amount": {
      "type": "number",
      "minimum": 0.01,
      "maximum": 999999999.99,
      "description": "Interbank settlement amount"
    },
    "interbank_settlement_currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$",
      "description": "ISO 4217 currency code"
    },
    "interbank_settlement_date": {
      "type": "string",
      "description": "Interbank settlement date (ISO date)"
    },
    "debtor_agent_bic": {
      "type": "string",
      "pattern": "^[A-Z0-9]{6}[A-Z0-9]{2}([A-Z0-9]{3})?$",
      "description": "Debtor agent BIC"
    },
    "creditor_agent_bic": {
      "type": "string",
      "pattern": "^[A-Z0-9]{6}[A-Z0-9]{2}([A-Z0-9]{3})?$",
      "description": "Creditor agent BIC"
    },
    "intermediary_agent1_bic": {
      "type": "string",
      "pattern": "^[A-Z0-9]{6}[A-Z0-9]{2}([A-Z0-9]{3})?$",
      "description": "Intermediary agent 1 BIC"
    },
    "instg_agt_bic": {
      "type": "string",
      "pattern": "^[A-Z0-9]{6}[A-Z0-9]{2}([A-Z0-9]{3})?$",
      "description": "Instructing agent BIC"
    },
    "instd_agt_bic": {
      "type": "string",
      "pattern": "^[A-Z0-9]{6}[A-Z0-9]{2}([A-Z0-9]{3})?$",
      "description": "Instructed agent BIC"
    }
  },
  "additionalProperties": true
}
