{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pacs.004.001.11 Payment Data Schema",
  "description": "Schema for ISO 20022 pacs.004.001.11 Payment Return",
  "version": "0.0.1",
  "type": "object",
  "required": [
    "msg_id",
    "creation_date_time",
    "original_msg_id",
    "original_msg_nm_id",
    "returned_interbank_settlement_amount",
    "returned_interbank_settlement_currency",
    "return_reason_cd"
  ],
  "properties": {
    "msg_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 35,
      "description": "Message identification"
    },
    "creation_date_time": {
      "type": "string",
      "description": "Creation date and time"
    },
    "nb_of_txs": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of transactions"
    },
    "original_msg_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 35,
      "description": "Original message identification"
    },
    "original_msg_nm_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 35,
      "description": "Original message name identification"
    },
    "original_end_to_end_id": {
      "type": "string",
      "maxLength": 35,
      "description": "Original end-to-end identification"
    },
    "original_tx_id": {
      "type": "string",
      "maxLength": 35,
      "description": "Original transaction identification"
    },
    "returned_interbank_settlement_amount": {
      "type": "number",
      "minimum": 0.01,
      "maximum": 999999999.99,
      "description": "Returned interbank settlement amount"
    },
    "returned_interbank_settlement_currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$",
      "description": "Returned interbank settlement currency (ISO 4217)"
    },
    "return_reason_cd": {
      "type": "string",
      "maxLength": 4,
      "description": "Return reason code (e.g., AC01, AM04, MS02)"
    },
    "return_reason_addtl_inf": {
      "type": "string",
      "maxLength": 105,
      "description": "Return reason additional information"
    },
    "instg_agt_bic": {
      "type": "string",
      "pattern": "^[A-Z0-9]{6}[A-Z0-9]{2}([A-Z0-9]{3})?$",
      "description": "Instructing agent BIC"
    },
    "instd_agt_bic": {
      "type": "string",
      "pattern": "^[A-Z0-9]{6}[A-Z0-9]{2}([A-Z0-9]{3})?$",
      "description": "Instructed agent BIC"
    }
  },
  "additionalProperties": true
}
