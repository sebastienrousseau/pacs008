{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pacs.003.001.09 Payment Data Schema",
  "description": "Schema for ISO 20022 pacs.003.001.09 FI-to-FI Customer Direct Debit",
  "version": "0.0.1",
  "type": "object",
  "required": [
    "msg_id",
    "creation_date_time",
    "nb_of_txs",
    "settlement_method",
    "end_to_end_id",
    "interbank_settlement_amount",
    "interbank_settlement_currency",
    "charge_bearer",
    "debtor_name",
    "debtor_agent_bic",
    "creditor_agent_bic",
    "creditor_name",
    "mandate_id",
    "seq_tp"
  ],
  "properties": {
    "msg_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 35,
      "description": "Message identification"
    },
    "creation_date_time": {
      "type": "string",
      "description": "Creation date and time"
    },
    "nb_of_txs": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of transactions"
    },
    "settlement_method": {
      "type": "string",
      "enum": [
        "INGA",
        "INDA",
        "CLRG",
        "COVE"
      ],
      "description": "Settlement method"
    },
    "end_to_end_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 35,
      "description": "End-to-end transaction identifier"
    },
    "tx_id": {
      "type": "string",
      "maxLength": 35,
      "description": "Transaction identification"
    },
    "interbank_settlement_amount": {
      "type": "number",
      "minimum": 0.01,
      "maximum": 999999999.99,
      "description": "Interbank settlement amount"
    },
    "interbank_settlement_currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$",
      "description": "ISO 4217 currency code"
    },
    "interbank_settlement_date": {
      "type": "string",
      "description": "Interbank settlement date (ISO date)"
    },
    "charge_bearer": {
      "type": "string",
      "enum": [
        "DEBT",
        "CRED",
        "SHAR",
        "SLEV"
      ],
      "description": "Charge bearer code"
    },
    "mandate_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 35,
      "description": "Mandate identification"
    },
    "seq_tp": {
      "type": "string",
      "enum": [
        "FRST",
        "RCUR",
        "FNAL",
        "OOFF"
      ],
      "description": "Sequence type"
    },
    "debtor_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 140,
      "description": "Debtor name"
    },
    "debtor_account_iban": {
      "type": "string",
      "pattern": "^[A-Z]{2}[0-9]{2}[A-Z0-9]+$",
      "minLength": 15,
      "maxLength": 34,
      "description": "Debtor account IBAN"
    },
    "debtor_agent_bic": {
      "type": "string",
      "pattern": "^[A-Z0-9]{6}[A-Z0-9]{2}([A-Z0-9]{3})?$",
      "description": "Debtor agent BIC"
    },
    "creditor_agent_bic": {
      "type": "string",
      "pattern": "^[A-Z0-9]{6}[A-Z0-9]{2}([A-Z0-9]{3})?$",
      "description": "Creditor agent BIC"
    },
    "creditor_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 140,
      "description": "Creditor name"
    },
    "creditor_account_iban": {
      "type": "string",
      "pattern": "^[A-Z]{2}[0-9]{2}[A-Z0-9]+$",
      "minLength": 15,
      "maxLength": 34,
      "description": "Creditor account IBAN"
    },
    "remittance_information": {
      "type": "string",
      "maxLength": 140,
      "description": "Remittance information"
    },
    "instg_agt_bic": {
      "type": "string",
      "pattern": "^[A-Z0-9]{6}[A-Z0-9]{2}([A-Z0-9]{3})?$",
      "description": "Instructing agent BIC"
    },
    "instd_agt_bic": {
      "type": "string",
      "pattern": "^[A-Z0-9]{6}[A-Z0-9]{2}([A-Z0-9]{3})?$",
      "description": "Instructed agent BIC"
    }
  },
  "additionalProperties": true
}
